# Variables de entorno — Cabelma-OS
# Copiá este archivo a .env y completá los valores reales.
# NUNCA subas .env a GitHub.

# AI Provider (claude / openai / gemini)
AI_PROVIDER=claude

# Anthropic / Claude API
ANTHROPIC_API_KEY=

# OpenAI / Codex API (opcional)
OPENAI_API_KEY=

# Google Gemini API (opcional — Gemini CLI usa auth de cuenta Google por defecto)
GEMINI_API_KEY=

# Softland (si conectás vía script — solo credenciales de app, nunca usuario personal)
# SOFTLAND_SERVER=
# SOFTLAND_DB=
# SOFTLAND_USER=
# SOFTLAND_PASS=
